---
interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  publishedOn?: Date;
  updatedOn?: Date;
  previousPostUrl?: string;
  nextPostUrl?: string;
  enablePostListShortcuts?: boolean;
}

const {
  title,
  description,
  type = 'website',
  publishedOn,
  updatedOn,
  previousPostUrl,
  nextPostUrl,
  enablePostListShortcuts = false,
} = Astro.props;
const base = import.meta.env.BASE_URL;
const canonicalUrl = Astro.url.href.replace(/\.html$/, '').replace(/\/index$/, '/');
const siteName = "Luciano's blog";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} />
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('theme');
          const dark = stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches);
          document.documentElement.dataset.theme = dark ? 'dark' : 'light';
        } catch {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
    <link rel="stylesheet" href={`${base}styles/global.css`} />
    <script defer src="https://cloud.umami.is/script.js" data-website-id="5027eb92-ec33-4e41-a40c-a944a2dc66d7"></script>

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {type === 'article' && publishedOn && <meta property="article:published_time" content={publishedOn.toISOString()} />}
    {type === 'article' && updatedOn && <meta property="article:modified_time" content={updatedOn.toISOString()} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
  </head>
  <body
    data-enable-post-list-shortcuts={enablePostListShortcuts ? 'true' : 'false'}
    data-previous-post-url={previousPostUrl}
    data-next-post-url={nextPostUrl}
  >
    <header class="site-header">
      <nav>
        <a href={base}>Luciano's blog</a>
        <div class="nav-right">
          <button id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode"></button>
          <a
            class="github-link"
            href="https://github.com/lgoncalv/blog.luciano.goncalves.dev"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub repository"
          >
            <img src={`${base}github-mark-light-32px.png`} width="32" height="32" alt="GitHub" />
          </a>
        </div>
      </nav>
    </header>

    <main class="site-main">
      <slot />
    </main>

    {(enablePostListShortcuts || type === 'article') && (
      <aside class="shortcut-help" data-shortcut-help>
        <button
          type="button"
          class="shortcut-help-toggle"
          data-shortcut-help-toggle
          aria-label="Toggle keyboard shortcuts help"
          aria-expanded="false"
          title="Keyboard shortcuts"
        >
          ⌨ Shortcuts (?)
        </button>
        <div class="shortcut-help-panel" data-shortcut-help-panel hidden>
          <ul>
            <li><kbd>j</kbd> Next post</li>
            <li><kbd>k</kbd> Previous post</li>
            <li><kbd>d</kbd> Toggle dark mode</li>
            <li><kbd>?</kbd> Toggle shortcuts help</li>
            <li><kbd>Esc</kbd> Close shortcuts help</li>
          </ul>
        </div>
      </aside>
    )}

    <script>
      const themeToggleButton = document.getElementById('theme-toggle');
      themeToggleButton?.addEventListener('click', () => {
        const el = document.documentElement;
        const next = el.dataset.theme === 'dark' ? 'light' : 'dark';
        el.dataset.theme = next;
        localStorage.setItem('theme', next);
      });

      const desktopQuery = window.matchMedia('(hover: hover) and (pointer: fine) and (min-width: 1024px)');
      const previousPostUrl = document.body.dataset.previousPostUrl;
      const nextPostUrl = document.body.dataset.nextPostUrl;
      const enablePostListShortcuts = document.body.dataset.enablePostListShortcuts === 'true';

      const helpRoot = document.querySelector<HTMLElement>('[data-shortcut-help]');
      const helpToggle = document.querySelector<HTMLButtonElement>('[data-shortcut-help-toggle]');
      const helpPanel = document.querySelector<HTMLElement>('[data-shortcut-help-panel]');

      const postArticles = enablePostListShortcuts
        ? Array.from(document.querySelectorAll<HTMLElement>('article.post'))
        : [];
      let selectedPostIndex = -1;

      const setHelpOpen = (open: boolean) => {
        if (!helpToggle || !helpPanel) return;
        helpToggle.setAttribute('aria-expanded', String(open));
        helpPanel.hidden = !open;
      };

      const clearSelectedPost = () => {
        if (selectedPostIndex < 0) return;
        postArticles[selectedPostIndex]?.classList.remove('is-kbd-selected');
        selectedPostIndex = -1;
      };

      const selectPostAtIndex = (index: number) => {
        if (!postArticles.length) return;

        clearSelectedPost();

        selectedPostIndex = Math.max(0, Math.min(index, postArticles.length - 1));
        const article = postArticles[selectedPostIndex];
        if (!article) return;

        article.classList.add('is-kbd-selected');
        article.scrollIntoView({ behavior: 'smooth', block: 'start' });
      };

      helpToggle?.addEventListener('click', () => {
        if (!helpPanel) return;
        setHelpOpen(helpPanel.hidden);
      });

      const isEditableTarget = (target: EventTarget | null) => {
        if (!(target instanceof HTMLElement)) return false;
        return Boolean(target.closest('input, textarea, select, [contenteditable="true"]'));
      };

      document.addEventListener('keydown', (event) => {
        if (!desktopQuery.matches) return;
        if (event.metaKey || event.ctrlKey || event.altKey) return;
        if (isEditableTarget(event.target)) return;

        const key = event.key;
        const lower = key.toLowerCase();

        if (event.repeat && (lower === 'j' || lower === 'k' || lower === 'd')) return;

        if (key === '?' || (key === '/' && event.shiftKey)) {
          if (!helpRoot || !helpPanel) return;
          event.preventDefault();
          setHelpOpen(helpPanel.hidden);
          return;
        }

        if (key === 'Escape') {
          if (helpRoot && helpPanel && !helpPanel.hidden) {
            setHelpOpen(false);
            return;
          }

          if (selectedPostIndex >= 0) {
            event.preventDefault();
            clearSelectedPost();
          }
          return;
        }

        if (lower === 'd') {
          event.preventDefault();
          themeToggleButton?.click();
          return;
        }

        if (lower === 'j') {
          if (postArticles.length) {
            event.preventDefault();
            selectPostAtIndex(selectedPostIndex < 0 ? 0 : selectedPostIndex + 1);
            return;
          }

          if (nextPostUrl) {
            event.preventDefault();
            window.location.assign(nextPostUrl);
          }
          return;
        }

        if (lower === 'k') {
          if (postArticles.length) {
            event.preventDefault();
            selectPostAtIndex(selectedPostIndex < 0 ? 0 : selectedPostIndex - 1);
            return;
          }

          if (previousPostUrl) {
            event.preventDefault();
            window.location.assign(previousPostUrl);
          }
        }
      });
    </script>
    <script>
      import mermaid from 'mermaid';

      mermaid.initialize({ startOnLoad: false, theme: 'neutral' });

      const blocks = document.querySelectorAll('pre[data-language="mermaid"] code');
      for (const block of blocks) {
        const pre = block.parentElement!;
        const text = [...block.querySelectorAll('.line')].map(l => l.textContent).join('\n') || (block.textContent ?? '');
        const id = `mermaid-${Math.random().toString(36).slice(2, 9)}`;
        mermaid.render(id, text).then(({ svg }) => {
          pre.outerHTML = `<div class="mermaid-container">${svg}</div>`;
        }).catch(() => {
          // leave the original code block on render failure
        });
      }
    </script>
  </body>
</html>
